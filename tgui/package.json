{
  "private": true,
  "name": "tgui-workspace",
  "version": "4.3.0",
  "packageManager": "yarn@4.15.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "tgui:analyze": "vite build --mode production --sourcemap --config vite.tgui.config.cjs && vite build --mode production --sourcemap --config vite.tgui-panel.config.cjs",
    "tgui:build": "vite build --mode production --config vite.tgui.config.cjs && vite build --mode production --config vite.tgui-panel.config.cjs",
    "tgui:dev": "node scripts/vite-dev.cjs",
    "tgui:lint": "eslint packages --ext .js,.cjs,.ts,.tsx",
    "tgui:prettier": "prettierx --check .",
    "tgui:sonar": "eslint packages --ext .js,.cjs,.ts,.tsx -c .eslintrc-harder.yml",
    "tgui:test": "jest --watch",
    "tgui:test-simple": "CI=true jest --color",
    "tgui:test-ci": "CI=true jest --color --collect-coverage",
    "tgui:tsc": "tsc"
  },
  "dependencies": {
    "@babel/code-frame": "^7.29.0",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/generator": "^7.29.1",
    "@babel/helper-environment-visitor": "^7.24.7",
    "@babel/helper-function-name": "^7.24.7",
    "@babel/helper-hoist-variables": "^7.24.7",
    "@babel/helper-split-export-declaration": "^7.24.7",
    "@babel/parser": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/types": "^7.29.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/parser": "^8.55.0",
    "babel-jest": "^30.2.0",
    "babel-plugin-inferno": "^6.8.5",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "common": "workspace:*",
    "debug": "^4.4.3",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "inferno": "^9.0.11",
    "jest": "^30.2.0",
    "jest-circus": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.0.0",
    "katex": "^0.16.28",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.97.3",
    "terser": "^5.43.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependenciesMeta": {
    "esbuild": {
      "unplugged": true
    },
    "vite": {
      "unplugged": true
    }
  }
}
