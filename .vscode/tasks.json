{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": "dm: reparse",
			"label": "Build All"
		},
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build"
			},
			"dependsOn": "dm: reparse",
			"args": [
				"-DUSE_BYOND_TRACY"
			],
			"label": "Build All (TRACY)"
		},
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build"
			},
			"dependsOn": "dm: reparse",
			"args": [
				"-DTESTING"
			],
			"label": "Build All (TESTING)"
		},
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build"
			},
			"dependsOn": "dm: reparse",
			"args": [
				"-DLOWMEMORYMODE"
			],
			"label": "Build All (LOWMEMORYMODE)"
		},
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build"
			},
			"dependsOn": "dm: reparse",
			"args": [
				"-DLOWMEMORYMODE",
				"-DUSE_BYOND_TRACY"
			],
			"label": "Build All (LOWMEMORYMODE TRACY)"
		},
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build"
			},
			"dependsOn": "dm: reparse",
			"args": [
				"-DLOWMEMORYMODE",
				"-DABSOLUTE_MINIMUM_MODE"
			],
			"label": "Build All (ABSOLUTE MINIMUM)"
		},
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build"
			},
			"dependsOn": "dm: reparse",
			"args": [
				"-DTESTING",
				"-DREFERENCE_TRACKING",
				"-DGC_FAILURE_HARD_LOOKUP"
			],
			"label": "Build All (REFERENCE_TRACKING)"
		},
		{
			"type": "process",
			"command": "tools/build/build",
			"windows": {
				"command": ".\\tools\\build\\build.bat"
			},
			"options": {
				"env": {
					"DM_EXE": "${config:dreammaker.byondPath}"
				}
			},
			"problemMatcher": [
				"$dreammaker",
				"$tsc",
				"$eslint-stylish"
			],
			"group": {
				"kind": "build"
			},
			"dependsOn": "dm: reparse",
			"args": [
				"-DGC_PROFILER"
			],
			"label": "Build All (GC_PROFILER)"
		},
		{
			"type": "dreammaker",
			"dme": "tgstation.dme",
			"problemMatcher": [
				"$dreammaker"
			],
			"group": "build",
			"label": "dm: build - tgstation.dme"
		},
		{
			"type": "shell",
			"command": "tgui/bin/tgui",
			"windows": {
				"command": ".\\tgui\\bin\\tgui.bat"
			},
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"group": "build",
			"label": "tgui: build"
		},
		{
			"type": "shell",
			"command": "tgui/bin/tgui",
			"windows": {
				"command": ".\\tgui\\bin\\tgui.bat"
			},
			"args": [
				"--dev"
			],
			"isBackground": true,
			"problemMatcher": {
				"owner": "tgui-dev",
				"pattern": {
					"regexp": "^\\[NEVER_MATCH\\] (.+):(\\d+):(\\d+): (.+)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"message": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "vite v|building client environment|build started",
					"endsPattern": "dev-server: http\\+ws on"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "tgui"
			},
			"detail": "Запускает vite-watch и dev-сервер (http+ws на :3000) для hot-reload. Требует Node 20/22 и TGUI_DEV_SERVER_IP в конфиге.",
			"label": "tgui: dev (hot-reload)"
		},
		{
			"type": "shell",
			"command": "tgui/bin/tgui",
			"windows": {
				"command": ".\\tgui\\bin\\tgui.bat"
			},
			"args": [
				"--lint"
			],
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"group": "build",
			"detail": "ESLint + проверка типов TypeScript для tgui.",
			"label": "tgui: lint"
		},
		{
			"type": "shell",
			"command": "tgui/bin/tgui",
			"windows": {
				"command": ".\\tgui\\bin\\tgui.bat"
			},
			"args": [
				"--test"
			],
			"problemMatcher": [],
			"group": "test",
			"detail": "Jest-тесты tgui.",
			"label": "tgui: test"
		},
		{
			"dependsOrder": "sequence",
			"dependsOn": [
				"Build All (LOWMEMORYMODE)",
				"tgui: dev (hot-reload)"
			],
			"detail": "Сборка (LOWMEMORYMODE) + автозапуск dev hot-reload. preLaunchTask для DEV-конфига.",
			"label": "tgui: dev prelaunch (LOWMEMORYMODE)"
		},
		{
			"dependsOrder": "sequence",
			"dependsOn": [
				"Build All (TESTING)",
				"tgui: dev (hot-reload)"
			],
			"detail": "Сборка (TESTING) + автозапуск dev hot-reload. preLaunchTask для DEV-конфига.",
			"label": "tgui: dev prelaunch (TESTING)"
		},
		{
			"command": "${command:dreammaker.reparse}",
			"group": "build",
			"label": "dm: reparse"
		}
	]
}
